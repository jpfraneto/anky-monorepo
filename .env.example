# Server
PORT=8889

# Ollama (currently qwen3.5:27b)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:27b

# ComfyUI (local Flux image generation)
COMFYUI_URL=http://localhost:8188

# Anthropic (Claude) — required for writing analysis
ANTHROPIC_API_KEY=

# OpenRouter — primary routing for user-facing writing replies
OPENROUTER_API_KEY=
OPENROUTER_LIGHT_MODEL=meta-llama/llama-4-scout:free
OPENROUTER_ANKY_MODEL=anthropic/claude-opus-4.6

# Google Gemini — required for image generation
GEMINI_API_KEY=

# Instagram Graph API (preferred source of truth for social posting)
# Use a professional Instagram account linked to a Facebook Page.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# Base Chain
BASE_RPC_URL=https://mainnet.base.org
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
TREASURY_ADDRESS=

# x402 Payment Facilitator (optional)
X402_FACILITATOR_URL=https://x402.org/facilitator

# Mind (local llama-server inference on GPU 0)
MIND_URL=http://127.0.0.1:8080

# Redis/Valkey (job persistence)
REDIS_URL=redis://127.0.0.1:6379

# X/Twitter API (social posting)
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Solana Bubblegum minting (Sojourn 9)
SOLANA_MINT_WORKER_URL=https://anky-mint.<subdomain>.workers.dev
SOLANA_MINT_WORKER_SECRET=
SOLANA_MERKLE_TREE=
SOLANA_COLLECTION_MINT=
SOLANA_AUTHORITY_PUBKEY=
HELIUS_API_KEY=

# Cloudflare R2 (image + audio CDN storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=anky-images
R2_PUBLIC_URL=https://cdn.anky.app

# iOS app install fallback for /seal bridge
ANKY_IOS_APP_URL=https://testflight.apple.com/join/WcRYyCm5
