{
  "name": "anky-loom-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Generate a privacy-preserving SVG loom from .anky timing files.",
  "main": "dist/index.js",
  "bin": {
    "anky-loom-engine": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "generate": "npm run build --silent && node dist/cli.js"
  },
  "keywords": [
    "anky",
    "loom",
    "svg",
    "rhythm"
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.3"
  }
}
